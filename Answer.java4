server:   port: 4002  spring:   application:     name: VehicleMS
  datasource:     driverClassName: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/vehicle_db
    username: root
    password: root
  jpa:     hibernate.ddl-auto: update
  cloud:     consul:       host: localhost
      port: 8500       discovery:         service-name: VehicleMS
        enabled: true  API:   INSERT_SUCCESS: Vehicle added successfully with vehicle id.
 Service:   VEHICLE_FOUND: Vehicle Id Already Exist.
  VEHICLE_NOT_FOUND: Vehicle Id Not Found.
  VEHICLETYPE_NOT_FOUND: Vehicle Type and Vacancy Not Found
 General:   EXCEPTION_MESSAGE: "Request could not be processed due to some issue. Please try again!"

14. VehicleMS Database Script



sql

DROP SCHEMA IF EXISTS vehicle_db;  CREATE SCHEMA vehicle_db; USE vehicle_db;  CREATE TABLE vehicle (     vehicle_id INT(10) PRIMARY KEY AUTO_INCREMENT,     vehicle_type VARCHAR(50) NOT NULL,     vacancy INT NOT NULL,     date DATE NOT NULL );  INSERT INTO vehicle(vehicle_type, vacancy, date) VALUES ('TwoWheeler', 20, '2024-12-10'); INSERT INTO vehicle(vehicle_type, vacancy, date) VALUES ('FourWheeler', 23, '2024-01-20'); INSERT INTO vehicle(vehicle_type, vacancy, date) VALUES ('TwoWheeler', 24, '2024-02-28'); INSERT INTO vehicle(vehicle_type, vacancy, date) VALUES ('TwoWheeler', 25, '2024-02-29'); INSERT INTO vehicle(vehicle_type, vacancy, date) VALUES ('FourWheeler', 15, '2024-03-15'); INSERT INTO vehicle(vehicle_type, vacancy, date) VALUES ('TwoWheeler', 18, '2024-04-01');  DELIMITER // CREATE PROCEDURE GetAllVehiclesByType(IN p_vehicle_type VARCHAR(50)) BEGIN    SELECT vehicle_id, vehicle_type, vacancy, date 
   FROM vehicle 
   WHERE vehicle_type = p_vehicle_type; END // DELIMITER ;  SELECT * FRO
