1. Vehicle Entity Class



java

package com.infy.vehicle.entity;  import jakarta.persistence.*; import lombok.AllArgsConstructor; import lombok.Data; import lombok.NoArgsConstructor;  @Entity @Table(name = "vehicle") @Data @NoArgsConstructor @AllArgsConstructor public class Vehicle {     
    @Id     @GeneratedValue(strategy = GenerationType.IDENTITY)     @Column(name = "vehicle_id")     private Integer vehicleId;     
    @Column(name = "vehicle_type")     private String vehicleType;     
    @Column(name = "vacancy")     private Integer vacancies;     
    @Column(name = "date")     private String date; }

