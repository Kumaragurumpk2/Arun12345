3. Vehicle Repository Interface



java

package com.infy.vehicle.repository;  import com.infy.vehicle.entity.Vehicle; import org.springframework.data.jpa.repository.JpaRepository; import org.springframework.data.jpa.repository.Query; import org.springframework.data.repository.query.Param; import org.springframework.stereotype.Repository;  import java.util.List;  @Repository public interface VehicleRepository extends JpaRepository<Vehicle, Integer> {     
    @Query(value = "CALL GetAllVehiclesByType(:vehicleType)", nativeQuery = true)     List<Vehicle> getAllVehiclesByType(@Param("vehicleType") String vehicleType); }

4. Vehicle Service Interface



java

package com.infy.vehicle.service;  import com.infy.vehicle.dto.VehicleDTO; import com.infy.vehicle.exception.VehicleException; import java.util.List;  public interface VehicleService {     
    public VehicleDTO getVehicle(Integer vehicleId) throws VehicleException;     
    public List<VehicleDTO> getAllVehicle(String vehicleType) throws VehicleException; }

5. Vehicle Service Implementation



java

package com.infy.vehicle.service;  import com.infy.vehicle.dto.VehicleDTO; import com.infy.vehicle.entity.Vehicle; import com.infy.vehicle.exception.VehicleException; import com.infy.vehicle.repository.VehicleRepository; import org.modelmapper.ModelMapper; import org.springframework.beans.factory.annotation.Autowired; import org.springframework.stereotype.Service; import org.springframework.transaction.annotation.Transactional;  import java.util.List; import java.util.Optional; import java.util.stream.Collectors;  @Service(value = "vehicleService") @Transactional public class VehicleServiceImpl implements VehicleService {     
    @Autowired     private VehicleRepository vehicleRepository;     
    @Autowired     private ModelMapper modelMapper;     
    @Override     public VehicleDTO getVehicle(Integer vehicleId) throws VehicleException {         Optional<Vehicle> vehicle = vehicleRepository.findById(vehicleId);         if (vehicle.isPresent()) {             return modelMapper.map(vehicle.get(), VehicleDTO.class);         }         throw new VehicleException("Service.VEHICLE_NOT_FOUND");     }     
    @Override     public List<VehicleDTO> getAllVehicle(String vehicleType) throws VehicleException {         List<Vehicle> vehicles = vehicleRepository.getAllVehiclesByType(vehicleType);         
        if (vehicles.isEmpty()) {             throw new VehicleException("Service.VEHICLETYPE_NOT_FOUND");         }         
        // Sort in ascending order of vacancies         vehicles.sort((v1, v2) -> v1.getVacancies().compareTo(v2.getVacancies()));         
        // Convert to DTO and convert vehicleType to uppercase         List<VehicleDTO> vehicleDTOs = vehicles.stream()             .map(vehicle -> {                 VehicleDTO dto = modelMapper.map(vehicle, VehicleDTO.class);                 dto.setVehicleType(vehicle.getVehicleType().toUpperCase());                 return dto;             })             .collect(Collectors.toList());         
        return vehicleDTOs;     } }

6. Vehicle API Controller



java

package com.infy.vehicle.api;  import com.infy.vehicle.dto.VehicleDTO; import com.infy.vehicle.exception.VehicleException; import com.infy.vehicle.service.VehicleService; import org.springframework.beans.factory.annotation.Autowired; import org.springframework.http.HttpStatus; import org.springframework.http.ResponseEntity; import org.springframework.web.bind.annotation.*;  import java.util.List;  @RestController @RequestMapping("/vehicles") public class VehicleAPI {     
    @Autowired     private VehicleService vehicleService;     
    @GetMapping("/vehicle")     public ResponseEntity<VehicleDTO> getVehicle(@RequestParam Integer vehicleId) throws VehicleException {         if (vehicleId == 999) {             throw new RuntimeException("Testing fallback method..!");         }         return new ResponseEntity<>(vehicleService.getVehicle(vehicleId), HttpStatus.OK);     }     
    @GetMapping("/{vehicleType}")     public ResponseEntity<List<VehicleDTO>> getAllVehicle(@PathVariable String vehicleType) throws VehicleException {         List<VehicleDTO> vehicleDTOs = vehicleService.getAllVehicle(vehicleType);         return new ResponseEntity<>(vehicleDTOs, HttpStatus.OK);     } }

