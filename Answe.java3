-- Stored Procedure to get all vehicles by type
DELIMITER //
CREATE PROCEDURE GetAllVehiclesByType(IN p_vehicle_type VARCHAR(50))
BEGIN
   SELECT vehicle_id, vehicle_type, vacancy, date 
   FROM vehicle 
   WHERE vehicle_type = p_vehicle_type;
END //
DELIMITER ;

