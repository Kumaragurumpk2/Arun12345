DROP SCHEMA IF EXISTS vehicle_db;

CREATE SCHEMA vehicle_db;
USE vehicle_db;

CREATE TABLE vehicle (
    vehicle_id INT(10) PRIMARY KEY,
    vehicle_type VARCHAR(50) NOT NULL,
       vacancy INT NOT NULL,
       date DATE NOT NULL

);

