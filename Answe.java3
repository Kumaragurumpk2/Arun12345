        {
            return new ModelMapper();
        }
}
package com.infy.vehicle.api;

import java.util.List;

import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;

import com.infy.vehicle.dto.VehicleDTO;
import com.infy.vehicle.exception.VehicleException;
import com.infy.vehicle.service.VehicleService;

public class VehicleAPI {

    private VehicleService vehicleService;

    public ResponseEntity<VehicleDTO> getVehicle(Integer vehicleId) throws VehicleException {
        if (vehicleId == 999) {
            throw new RuntimeException("Testing fallback method..!");
        }
        return new ResponseEntity<>(vehicleService.getVehicle(vehicleId), HttpStatus.OK);
    }

    public ResponseEntity<List<VehicleDTO>> getAllVehicle(String vehicleType) throws VehicleException {
        List<VehicleDTO> vehicleDTOs = vehicleService.getAllVehicle(vehicleType);
        return new ResponseEntity<>(vehicleDTOs, HttpStatus.OK);
    }

}


